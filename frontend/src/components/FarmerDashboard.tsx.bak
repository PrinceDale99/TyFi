            </div>
          )}
        </ParallaxCard>
      </div>

      {/* Secondary Grid */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        {/* Farm Portfolio */}
        <ParallaxCard className="lg:col-span-2 p-6">
