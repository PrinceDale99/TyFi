        </ParallaxCard>

      {/* Weather Mapping & Charts (Monitoring) */}
      <div className="grid grid-cols-1 gap-6">
        <div className="glass-panel min-h-[400px] relative overflow-hidden">
          <WeatherMap 
            weather={weather} 
            isLoading={isLoadingWeather} 
